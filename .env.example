# Production Environment Variables
FLASK_ENV=production
SECRET_KEY=your-super-secret-production-key-here
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=5000

# Update your BASE_URL to match your deployed server
# Examples:
# Heroku: BASE_URL=https://your-app-name.herokuapp.com
# Railway: BASE_URL=https://your-app-name.up.railway.app  
# Render: BASE_URL=https://your-app-name.onrender.com
# Azure: BASE_URL=https://your-app-name.azurewebsites.net
BASE_URL=http://localhost:5000

# Optional: Database URL (for future database integration)
# DATABASE_URL=postgresql://user:pass@hostname:port/database

# Optional: Storage settings (for future file storage integration)
# STORAGE_TYPE=local
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_BUCKET_NAME=your-bucket-name